# Jarvis IA - Configurações de Ambiente
# Copie este arquivo para .env e ajuste as configurações conforme necessário

# Configurações de Áudio
JARVIS_MICROPHONE_INDEX=3
JARVIS_VOICE=pt-BR-AntonioNeural

# Configurações de IA
JARVIS_AI_MODEL=llama3
JARVIS_MAX_HISTORY=20

# Configurações de Debug
JARVIS_DEBUG=false
JARVIS_VERBOSE_LOGGING=false

# Diretórios
JARVIS_LOG_DIR=logs

# Configurações de Segurança
JARVIS_ALLOW_SHUTDOWN=false
JARVIS_REQUIRE_CONFIRMATION=true